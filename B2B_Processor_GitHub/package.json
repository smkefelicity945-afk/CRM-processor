{
  "name": "b2b-order-processor",
  "version": "1.0.0",
  "description": "B2B Order Processor CRM Tool",
  "main": "main.js",
  "author": "CRM Team",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.crm.b2b",
    "productName": "B2B Order Processor",
    "directories": { "output": "release" },
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "icon": "icon.ico"
    },
    "files": ["main.js", "index.html", "icon.ico", "node_modules/**/*"]
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
